generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["plux"]
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. ENUMS (Domínio e Regras)
// ==========================================

enum PapelUsuario {
  ADMIN
  GERENTE
  CAIXA
}

enum StatusUsuario {
  ATIVO
  TESTE
  EXPIRADO
  PAGO
}

enum UnidadeMedida {
  G
  ML
  UN
  KG
  L
}

enum RegimeTributario {
  SIMPLES_NACIONAL
  MEI
  LUCRO_PRESUMIDO
  LUCRO_REAL
}

enum TipoIncidencia {
  NORMAL
  REDUZIDA_60 // Alíquota reduzida prevista na reforma
  REDUZIDA_100 // Cesta básica nacional (alíquota zero)
  IMPOSTO_SELETIVO // "Imposto do Pecado" para ultraprocessados/açucarados
}

enum ClassificacaoFiscal {
  TRIBUTADO
  IMUNE
  ISENTO
  NAO_INCIDENTE
  REDUCAO_BASE
  ALIQUOTA_ZERO
  SUBSTITUICAO_TRIBUTARIA
}

enum MetodoPagamentoVenda {
  DINHEIRO
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  VALE_REFEICAO
}

enum CategoriaProduto {
  HAMBURGUER_CARNE
  HAMBURGUER_FRANGO
  PRATOS
  A_LACARTE
  PORCOES
  CARNES
  BEBIDAS_ALCOOL
  SEM_ALCOOL
  REFRIGERANTES
  AGUAS
  BEBIDAS_QUENTES
  VINHOS
  CAFES
  SALGADOS
  DOCES
  MASSAS
}

enum TipoMovimentacaoEstoque {
  ENTRADA
  SAIDA
  DESPERDICIO
  AJUSTE
  INVENTARIO
}

enum MotivoDesperdicio {
  VENCIDO
  DANIFICADO
  PROCESSO
  ERRO_PEDIDO
  OUTRO
}

enum StatusComanda {
  PENDENTE
  PREPARANDO
  PRONTA
  ENTREGUE
}

// ==========================================
// 2. INFRAESTRUTURA E ACESSO
// ==========================================

model Locatario {
  id               String           @id @default(uuid())
  nome             String
  cnpj             String?          @unique
  regimeTributario RegimeTributario @default(SIMPLES_NACIONAL)
  uf               String           @db.VarChar(2)

  usuarios      Usuario[]
  ingredientes  Ingrediente[]
  produtos      Produto[]
  vendas        Venda[]
  setores       Setor[]
  movimentacoes MovimentacaoEstoque[]
  notificacoes  Notificacao[]
  configuracoes ConfiguracoesApp?
  logs          LogAtividade[]

  criadoEm        DateTime         @default(now())
  atualizadoEm    DateTime         @updatedAt
  sessaoCaixas    SessaoCaixa[]
  comandaCozinhas ComandaCozinha[]
  desperdicios    Desperdicio[]
}

model Usuario {
  id     String        @id @default(uuid())
  email  String        @unique
  nome   String
  papel  PapelUsuario
  status StatusUsuario
  avatar String?

  locatarioId String
  locatario   Locatario @relation(fields: [locatarioId], references: [id])

  desperdicios Desperdicio[]
  logs         LogAtividade[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

// ==========================================
// 3. NÚCLEO FISCAL (Normalização)
// ==========================================

model FiscalConfig {
  id     String  @id @default(uuid())
  ncm    String  @db.VarChar(8)
  cest   String? @db.VarChar(7)
  origem Int     @default(0)

  // Reforma Tributária (CBS/IBS/IS)
  tipoIncidencia TipoIncidencia @default(NORMAL)
  aliquotaIbs    Float?         @default(0)
  aliquotaCbs    Float?         @default(0)
  aliquotaIs     Float?         @default(0) // Imposto Seletivo

  // Legado (PIS/COFINS/ICMS) - Necessário para transição
  cstIcms   String? @db.VarChar(3)
  cstPis    String? @db.VarChar(2)
  cstCofins String? @db.VarChar(2)

  // Relacionamentos 1:1
  ingrediente Ingrediente?
  produto     Produto?
}

// ==========================================
// 4. SUPRIMENTOS (Ingredientes e Estoque)
// ==========================================

model Ingrediente {
  id           String  @id @default(uuid())
  nome         String
  codigoBarras String?

  // Gestão Financeira
  unidadeMedida    UnidadeMedida
  precoCustoUltimo Float         @default(0)
  custoMedio       Float         @default(0)
  estoqueAtual     Float         @default(0)

  // Fiscal
  fiscalConfigId String       @unique
  fiscalConfig   FiscalConfig @relation(fields: [fiscalConfigId], references: [id])

  locatarioId String
  locatario   Locatario @relation(fields: [locatarioId], references: [id])

  movimentacoes   MovimentacaoEstoque[]
  desperdicios    Desperdicio[]
  produtosQueUsam IngredienteProduto[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model MovimentacaoEstoque {
  id           String                  @id @default(uuid())
  quantidade   Float
  custoMomento Float // Importante para histórico de CMV
  tipo         TipoMovimentacaoEstoque
  observacoes  String?

  ingredienteId String
  ingrediente   Ingrediente @relation(fields: [ingredienteId], references: [id])
  locatarioId   String
  locatario     Locatario   @relation(fields: [locatarioId], references: [id])

  dataHora DateTime @default(now())
}

// ==========================================
// 5. COMERCIAL (Produtos e Vendas)
// ==========================================

model Produto {
  id         String  @id @default(uuid())
  nome       String
  sku        String?
  precoVenda Float
  ativo      Boolean @default(true)

  // Inteligência de Custo
  cmvTeorico Float @default(0) // Soma do custo dos ingredientes

  // Fiscal
  fiscalConfigId String           @unique
  fiscalConfig   FiscalConfig     @relation(fields: [fiscalConfigId], references: [id])
  categoria      CategoriaProduto

  ingredientes IngredienteProduto[]
  itensVenda   ItemVenda[]

  locatarioId String
  locatario   Locatario @relation(fields: [locatarioId], references: [id])

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model IngredienteProduto {
  id              String @id @default(uuid())
  quantidadeUsada Float

  produtoId     String
  produto       Produto     @relation(fields: [produtoId], references: [id])
  ingredienteId String
  ingrediente   Ingrediente @relation(fields: [ingredienteId], references: [id])

  @@unique([produtoId, ingredienteId])
}

model Venda {
  id              String               @id @default(uuid())
  receitaTotal    Float
  custoTotal      Float // CMV Real da venda
  metodoPagamento MetodoPagamentoVenda
  dataHora        DateTime             @default(now())

  itens    ItemVenda[]
  comandas ComandaCozinha[]

  locatarioId   String
  locatario     Locatario    @relation(fields: [locatarioId], references: [id])
  sessaoCaixaId String?
  sessaoCaixa   SessaoCaixa? @relation(fields: [sessaoCaixaId], references: [id])
}

model ItemVenda {
  id            String @id @default(uuid())
  quantidade    Float
  precoAplicado Float // Preço no momento da venda
  custoAplicado Float // Custo do produto no momento da venda

  vendaId   String
  venda     Venda   @relation(fields: [vendaId], references: [id])
  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])
}

// ==========================================
// 6. OPERACIONAL (Caixa e Salão)
// ==========================================

model SessaoCaixa {
  id              String    @id @default(uuid())
  abertoEm        DateTime  @default(now())
  fechadoEm       DateTime?
  valorAbertura   Float
  valorFechamento Float?
  status          String    @default("OPEN")

  vendas      Venda[]
  locatarioId String
  locatario   Locatario @relation(fields: [locatarioId], references: [id])
}

model Setor {
  id          String    @id @default(uuid())
  nome        String
  qtdMesas    Int       @default(0)
  locatarioId String
  locatario   Locatario @relation(fields: [locatarioId], references: [id])
}

model ComandaCozinha {
  id      String        @id @default(uuid())
  status  StatusComanda @default(PENDENTE)
  itens   Json // Snapshot dos itens para a cozinha
  vendaId String
  venda   Venda         @relation(fields: [vendaId], references: [id])

  locatarioId String
  locatario   Locatario @relation(fields: [locatarioId], references: [id])
}

model Desperdicio {
  id           String            @id @default(uuid())
  quantidade   Float
  motivo       MotivoDesperdicio
  custoMomento Float
  dataHora     DateTime          @default(now())

  usuarioId     String
  usuario       Usuario     @relation(fields: [usuarioId], references: [id])
  ingredienteId String
  ingrediente   Ingrediente @relation(fields: [ingredienteId], references: [id])
  locatarioId   String
  locatario     Locatario   @relation(fields: [locatarioId], references: [id])
}

// ==========================================
// 7. CONFIGURAÇÕES E AUDITORIA
// ==========================================

model ConfiguracoesApp {
  id                 String    @id @default(uuid())
  alertaEstoqueBaixo Float     @default(100)
  metaMensal         Float     @default(50000)
  locatarioId        String    @unique
  locatario          Locatario @relation(fields: [locatarioId], references: [id])
}

model LogAtividade {
  id       String   @id @default(uuid())
  acao     String
  entidade String
  detalhes String
  dataHora DateTime @default(now())

  usuarioId   String
  usuario     Usuario   @relation(fields: [usuarioId], references: [id])
  locatarioId String
  locatario   Locatario @relation(fields: [locatarioId], references: [id])
}

model Notificacao {
  id       String   @id @default(uuid())
  titulo   String
  mensagem String
  lida     Boolean  @default(false)
  dataHora DateTime @default(now())

  locatarioId String
  locatario   Locatario @relation(fields: [locatarioId], references: [id])
}
